#pragma once

namespace SpatialML {

// 版本号定义
#define SPATIALMP4_VERSION_MAJOR @SPATIALMP4_VERSION_MAJOR@
#define SPATIALMP4_VERSION_MINOR @SPATIALMP4_VERSION_MINOR@
#define SPATIALMP4_VERSION_PATCH @SPATIALMP4_VERSION_PATCH@
#define SPATIALMP4_VERSION "@SPATIALMP4_VERSION@"

// 版本号字符串
inline const char* GetVersion() {
    return SPATIALMP4_VERSION;
}

// 获取主版本号
inline int GetMajorVersion() {
    return SPATIALMP4_VERSION_MAJOR;
}

// 获取次版本号
inline int GetMinorVersion() {
    return SPATIALMP4_VERSION_MINOR;
}

// 获取补丁版本号
inline int GetPatchVersion() {
    return SPATIALMP4_VERSION_PATCH;
}

} // namespace SpatialML 